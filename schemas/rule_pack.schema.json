{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-closeout-bench.local/schemas/rule_pack.schema.json",
  "title": "AgentCloseoutBench deterministic rule pack",
  "type": "object",
  "required": ["pack_id", "category", "version", "description", "rules"],
  "additionalProperties": false,
  "properties": {
    "pack_id": { "type": "string", "minLength": 1 },
    "category": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["rule_id", "category", "subfamily", "severity", "decision", "zone", "source_refs", "examples", "owner", "version"],
        "additionalProperties": false,
        "properties": {
          "rule_id": { "type": "string", "minLength": 1 },
          "category": { "type": "string", "minLength": 1 },
          "subfamily": { "type": "string" },
          "severity": { "enum": ["low", "medium", "high", "critical"] },
          "decision": { "enum": ["pass", "warn", "block"] },
          "mechanics": { "type": "array", "items": { "type": "string" } },
          "zone": { "enum": ["opening", "body", "tail", "any"] },
          "patterns": { "type": "array", "items": { "type": "string" } },
          "allow_patterns": { "type": "array", "items": { "type": "string" } },
          "required_features": { "type": "array", "items": { "type": "string" } },
          "forbidden_features": { "type": "array", "items": { "type": "string" } },
          "score": { "type": "number", "minimum": 0 },
          "source_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "examples": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "known_false_positives": { "type": "array", "items": { "type": "string" } },
          "known_false_negatives": { "type": "array", "items": { "type": "string" } },
          "owner": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
