{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentcloseoutbench.local/schemas/public_source.schema.json",
  "title": "AgentCloseoutBench public source registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "updated_at", "sources"],
  "properties": {
    "schema_version": {
      "const": "agentcloseout.public_source_registry.v1"
    },
    "updated_at": {
      "type": "string"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_id",
          "title",
          "url",
          "tier",
          "license",
          "license_family",
          "terms_url",
          "schema_summary",
          "privacy_status",
          "allowed_use",
          "import_decision",
          "release_eligibility",
          "reviewer",
          "reviewed_at",
          "notes"
        ],
        "properties": {
          "source_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_\\-]{2,80}$"
          },
          "title": {
            "type": "string",
            "minLength": 3
          },
          "url": {
            "type": "string",
            "format": "uri"
          },
          "tier": {
            "enum": ["A", "B", "C"]
          },
          "license": {
            "type": "string",
            "minLength": 2
          },
          "license_family": {
            "enum": [
              "permissive",
              "copyleft_noncommercial",
              "paper_only",
              "platform_metadata",
              "unknown_pending_review"
            ]
          },
          "terms_url": {
            "type": "string"
          },
          "schema_summary": {
            "type": "string",
            "minLength": 8
          },
          "privacy_status": {
            "enum": [
              "public_dataset_previewed",
              "public_paper_only",
              "public_platform_guidance",
              "unknown_requires_review"
            ]
          },
          "allowed_use": {
            "type": "array",
            "minItems": 1,
            "items": {
              "enum": [
                "taxonomy",
                "analysis_only",
                "derived_fixtures",
                "trace_evidence_shape",
                "raw_fixture_release"
              ]
            }
          },
          "import_decision": {
            "enum": [
              "approved_for_redacted_derived_fixtures",
              "analysis_only_noncommercial",
              "taxonomy_only",
              "platform_guidance_only",
              "blocked_pending_license_review"
            ]
          },
          "release_eligibility": {
            "enum": [
              "releasable_after_redaction_review",
              "releasable_paraphrase_only",
              "not_releasable",
              "not_fixture_source"
            ]
          },
          "reviewer": {
            "type": "string",
            "minLength": 2
          },
          "reviewed_at": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
