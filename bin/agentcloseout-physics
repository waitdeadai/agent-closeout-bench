#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BIN="$ROOT_DIR/engine/target/release/agentcloseout-physics"

if [ -x "$BIN" ]; then
  exec "$BIN" "$@"
fi

if command -v cargo >/dev/null 2>&1; then
  exec cargo run --quiet --manifest-path "$ROOT_DIR/engine/Cargo.toml" -- "$@"
fi

if [ -f "$HOME/.cargo/env" ]; then
  # shellcheck disable=SC1090
  . "$HOME/.cargo/env"
fi

if command -v cargo >/dev/null 2>&1; then
  exec cargo run --quiet --manifest-path "$ROOT_DIR/engine/Cargo.toml" -- "$@"
fi

echo "agentcloseout-physics: Rust toolchain not found; install cargo or build engine/target/release/agentcloseout-physics" >&2
exit 127
